# Copy to .env and fill in — .env is gitignored
AI_GATEWAY_API_KEY=        # Vercel AI Gateway
TAVILY_API_KEY=
DATABASE_URL=              # local: postgresql://postgres:postgres@localhost:5433/mustang  prod: Neon pooled URL
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ask-mustangdriver
GOOGLE_CLIENT_ID=          # Google OAuth Client ID (Web app); empty disables Google sign-in
AUTH_JWT_SECRET=           # any long random string, e.g. `openssl rand -hex 32`
